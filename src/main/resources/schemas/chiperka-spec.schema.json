{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chiperka Specification",
  "description": "Schema for Chiperka specification files (*.chiperka) — kind: Service, Endpoint, or Test",
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "Service" } }, "required": ["kind"] },
      "then": { "$ref": "chiperka-service.schema.json" }
    },
    {
      "if": { "properties": { "kind": { "const": "Endpoint" } }, "required": ["kind"] },
      "then": { "$ref": "chiperka-endpoint.schema.json" }
    },
    {
      "if": { "properties": { "kind": { "const": "Test" } }, "required": ["kind"] },
      "then": { "$ref": "chiperka-test.schema.json" }
    }
  ]
}
