{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chiperka Service",
  "description": "Schema for kind: Service documents in *.chiperka files",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "description": "File kind discriminator",
      "const": "Service"
    },
    "metadata": { "$ref": "#/definitions/Metadata" },
    "spec": { "$ref": "#/definitions/ServiceSpec" }
  },
  "definitions": {
    "Metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique service name (referenced by `ref:` in tests)"
        },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ServiceSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": {
          "type": "string",
          "description": "OCI image reference (e.g. postgres:16)"
        },
        "command": {
          "description": "Override image CMD",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "workingDir": { "type": "string" },
        "environment": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "healthcheck": {
          "oneOf": [
            { "type": "boolean", "const": true },
            { "$ref": "#/definitions/HealthCheck" }
          ]
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/definitions/ServiceArtifact" }
        },
        "containerName": { "type": "string" },
        "weight": { "type": "integer", "default": 1 },
        "hooks": {
          "type": "array",
          "items": { "$ref": "#/definitions/Hook" }
        }
      }
    },
    "ServiceArtifact": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "HealthCheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "interval": { "type": "string", "default": "1s" },
        "timeout": { "type": "string", "default": "3s" },
        "retries": { "type": "integer", "default": 30 },
        "startPeriod": { "type": "string", "default": "0s" },
        "startInterval": { "type": "string" }
      }
    },
    "Hook": {
      "type": "object",
      "required": ["slot"],
      "additionalProperties": false,
      "properties": {
        "slot": {
          "type": "string",
          "enum": ["beforeExecution", "afterExecution"]
        },
        "priority": { "type": "integer", "default": 50 },
        "cli": {
          "type": "object",
          "required": ["command"],
          "additionalProperties": false,
          "properties": {
            "command": { "type": "string" },
            "workingDir": { "type": "string" }
          }
        },
        "diff": {
          "type": "object",
          "required": ["source", "target", "output"],
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string" },
            "target": { "type": "string" },
            "output": { "type": "string" }
          }
        }
      }
    }
  }
}
