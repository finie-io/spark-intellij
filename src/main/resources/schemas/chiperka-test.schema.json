{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chiperka Test",
  "description": "Schema for kind: Test documents in *.chiperka files (one Test per document)",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "description": "File kind discriminator",
      "const": "Test"
    },
    "metadata": {
      "$ref": "#/definitions/Metadata"
    },
    "spec": {
      "$ref": "#/definitions/TestSpec"
    }
  },
  "definitions": {
    "Metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Test name (unique within kind)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "tags": {
          "type": "array",
          "description": "Tags for filtering (e.g. smoke, api)",
          "items": { "type": "string" }
        }
      }
    },
    "TestSpec": {
      "type": "object",
      "required": ["endpoint", "execution", "assertions"],
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "metadata.name of the kind: Endpoint this test verifies"
        },
        "skipped": {
          "type": "boolean",
          "description": "Skip this test",
          "default": false
        },
        "services": {
          "type": "array",
          "description": "Services to start for this test (refs to kind: Service files)",
          "items": { "$ref": "#/definitions/Service" }
        },
        "setup": {
          "type": "array",
          "description": "Setup steps run after healthchecks but before test execution",
          "items": { "$ref": "#/definitions/SetupInstruction" }
        },
        "execution": {
          "$ref": "#/definitions/Execution",
          "description": "Test execution definition"
        },
        "assertions": {
          "type": "array",
          "description": "Expected outcomes to verify",
          "items": { "$ref": "#/definitions/Assertion" }
        },
        "teardown": {
          "type": "array",
          "description": "Teardown steps run after execution and assertions but before services are stopped",
          "items": { "$ref": "#/definitions/SetupInstruction" }
        }
      }
    },
    "Service": {
      "type": "object",
      "required": ["ref"],
      "additionalProperties": false,
      "description": "Reference to a kind: Service file. Inline service definitions are not supported.",
      "properties": {
        "ref": {
          "type": "string",
          "description": "metadata.name of the kind: Service to pull in"
        },
        "name": {
          "type": "string",
          "description": "Override the hostname used on the test network (defaults to ref)"
        },
        "containerName": {
          "type": "string",
          "description": "Explicit container name"
        },
        "environment": {
          "type": "object",
          "description": "Environment variable overrides (merged with template environment)",
          "additionalProperties": { "type": "string" }
        },
        "artifacts": {
          "type": "array",
          "description": "Additional artifacts to collect (appended to template artifacts)",
          "items": { "$ref": "#/definitions/ServiceArtifact" }
        }
      }
    },
    "ServiceArtifact": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Artifact name (defaults to filename or directory name from path)"
        },
        "path": {
          "type": "string",
          "description": "Path inside the container (file or directory)"
        }
      }
    },
    "SetupInstruction": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["http"],
          "properties": { "http": { "$ref": "#/definitions/SetupHTTP" } }
        },
        {
          "required": ["cli"],
          "properties": { "cli": { "$ref": "#/definitions/CLICommand" } }
        }
      ]
    },
    "SetupHTTP": {
      "type": "object",
      "required": ["target", "request"],
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "description": "Base URL (e.g. http://service:8080)"
        },
        "request": { "$ref": "#/definitions/HTTPRequest" }
      }
    },
    "Execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executor": {
          "type": "string",
          "description": "Executor type",
          "enum": ["http", "cli"]
        },
        "target": {
          "type": "string",
          "description": "Base URL for HTTP executor (e.g. http://api:8080)"
        },
        "request": {
          "$ref": "#/definitions/HTTPRequest",
          "description": "HTTP request definition (for HTTP executor)"
        },
        "cli": {
          "$ref": "#/definitions/CLICommand",
          "description": "CLI command definition (for CLI executor)"
        }
      }
    },
    "HTTPRequest": {
      "type": "object",
      "required": ["method", "url"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "description": "HTTP method",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        },
        "url": {
          "type": "string",
          "description": "Request path (e.g. /api/users)"
        },
        "headers": {
          "type": "object",
          "description": "HTTP headers",
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "description": "Request body: inline string, file reference, or multipart form data",
          "oneOf": [
            { "type": "string", "description": "Raw request body string" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "file": {
                  "type": "string",
                  "description": "Path to a file whose contents will be sent as the request body"
                }
              },
              "required": ["file"]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "multipart": {
                  "type": "object",
                  "description": "Multipart form data fields",
                  "additionalProperties": {
                    "oneOf": [
                      { "type": "string", "description": "Text field value" },
                      {
                        "type": "object",
                        "description": "File upload field",
                        "required": ["file"],
                        "additionalProperties": false,
                        "properties": {
                          "file": { "type": "string" },
                          "filename": { "type": "string" }
                        }
                      }
                    ]
                  }
                }
              },
              "required": ["multipart"]
            }
          ]
        }
      }
    },
    "CLICommand": {
      "type": "object",
      "required": ["service", "command"],
      "additionalProperties": false,
      "properties": {
        "service": {
          "type": "string",
          "description": "Service container to exec the command in"
        },
        "command": {
          "type": "string",
          "description": "Shell command (passed to sh -c)"
        },
        "workingDir": {
          "type": "string",
          "description": "Working directory for execution"
        }
      }
    },
    "Assertion": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["response"],
          "properties": { "response": { "$ref": "#/definitions/ResponseAssertion" } }
        },
        {
          "required": ["cli"],
          "properties": { "cli": { "$ref": "#/definitions/CLIAssertion" } }
        },
        {
          "required": ["artifact"],
          "properties": { "artifact": { "$ref": "#/definitions/ArtifactAssertion" } }
        }
      ]
    },
    "ResponseAssertion": {
      "type": "object",
      "additionalProperties": false,
      "description": "Assertions for HTTP response properties",
      "properties": {
        "statusCode": {
          "type": "integer",
          "description": "Expected HTTP status code"
        },
        "headers": {
          "type": "object",
          "description": "Header assertions keyed by header name",
          "additionalProperties": { "$ref": "#/definitions/HeaderMatcher" }
        },
        "body": {
          "$ref": "#/definitions/ResponseBodyAssertion"
        },
        "time": {
          "$ref": "#/definitions/ResponseTimeAssertion"
        }
      }
    },
    "HeaderMatcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "equals": { "type": "string" },
        "contains": { "type": "string" },
        "exists": { "type": "boolean" }
      }
    },
    "ResponseBodyAssertion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jsonPath": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "expected"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "expected": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "boolean" }
                ]
              }
            }
          }
        },
        "contains": { "type": "string" },
        "equals": { "type": "string" },
        "minSize": { "type": "integer" },
        "snapshot": { "type": "string" }
      }
    },
    "ResponseTimeAssertion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxMs": { "type": "integer" }
      }
    },
    "CLIAssertion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exitCode": { "type": "integer" },
        "stdout": { "$ref": "#/definitions/CLIOutputAssertion" },
        "stderr": { "$ref": "#/definitions/CLIOutputAssertion" }
      }
    },
    "CLIOutputAssertion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contains": { "type": "string" },
        "equals": { "type": "string" },
        "snapshot": { "type": "string" }
      }
    },
    "ArtifactAssertion": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "exists": { "type": "boolean" },
        "minSize": { "type": "integer" },
        "maxSize": { "type": "integer" },
        "snapshot": { "type": "string" }
      }
    }
  }
}
